# Variables de entorno para MigraCare
# Copia este archivo como '.env' e introduce tus credenciales de Supabase

# URL de la API de tu proyecto de Supabase (ej. https://abcdefghijklm.supabase.co)
VITE_SUPABASE_URL=tu_supabase_url_aqui

# Clave pública de Supabase Anon Key (se encuentra en Project Settings > API)
VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui
